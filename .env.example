# Meteologica "API markets" credentials — copy to .env and fill in.
# .env is gitignored; never commit real secrets.
METEOLOGICA_USERNAME=your_username_here
METEOLOGICA_PASSWORD=your_password_here

# Base URL for the API markets service
METEOLOGICA_BASE_URL=https://api-markets.meteologica.com

# Optional: EIA-930 (free) for ACTUAL ERCOT hourly gas generation → grounded gas burn.
# Register at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_key_here

# Optional: StormVista (paid subscription) — weighted degree days, ensembles, model bundles.
# Data API uses the API key as a query param (?apikey=) against
#   https://api.stormvistawxmodels.com/model-data/[model]/[YYYYMMDD]/[cycle]z/wdd/[file].csv
# STORMVISTA_API_KEY=your_subscriber_key   # from the /api page once logged in
# USER/PASSWORD are only needed to read the gated web docs, not for the data API:
# STORMVISTA_USER=
# STORMVISTA_PASSWORD=
